{
  "manifest_version": 2,
  "name": "AcademiQ Browser Capture",
  "version": "1.0.0",
  "description": "Yerel AcademiQ masaüstü uygulamasına makale yakalama uzantısı",
  "permissions": ["activeTab", "tabs", "storage", "alarms", "http://127.0.0.1/*", "https://*/*", "http://*/*"],
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "browser_action": {
    "default_title": "AcademiQ Capture",
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["browser-capture-utils.js", "detector.js"],
      "run_at": "document_idle"
    }
  ]
}
