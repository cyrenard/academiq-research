{
  "name": "academiq-research",
  "version": "1.24.0",
  "description": "AcademiQ Research - Akademik Yazim ve Kaynak Yonetim Uygulamasi",
  "main": "main.js",
  "author": "AcademiQ",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev:renderer": "vite --host 127.0.0.1",
    "build:renderer": "node scripts/build-renderer.js",
    "tauri:dev": "cargo tauri dev",
    "tauri:build": "cargo tauri build",
    "postinstall": "node scripts/sync-dictionary.js",
    "setup:dictionary": "node scripts/sync-dictionary.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test --test-concurrency=1 --test-isolation=none tests/*.test.js",
    "test:renderer": "vitest run",
    "test:renderer:watch": "vitest",
    "test:all": "npm test && npm run test:renderer",
    "gate:editor": "node scripts/editor-stability-gate.js",
    "gate:release": "node scripts/release-gate.js",
    "gate:tauri-bundle": "node scripts/tauri-bundle-gate.js",
    "release:baseline": "npm run build && npm run gate:release",
    "build": "node scripts/build-tauri.js",
    "build:electron": "node scripts/build-win.js",
    "build:dir": "node scripts/build-win.js --dir",
    "version:bump": "node scripts/bump-version.js"
  },
  "dependencies": {
    "dictionary-tr": "^2.0.0",
    "nspell": "^2.1.5",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/nspell": "^2.1.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "clsx": "^2.1.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.14.0",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "build": {
    "appId": "com.academiq.research",
    "productName": "AcademiQ Research",
    "copyright": "Copyright (c) 2024 AcademiQ",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "dist/renderer/**/*",
      "academiq-research.html",
      "tiptap-bundle.js",
      "vendor/**/*",
      "experiments/aq-engine/**/*",
      "browser-capture-extension/**/*",
      "!browser-capture-extension/chromium/config.js",
      "!browser-capture-extension/firefox/config.js",
      "icon.ico",
      "icon.png",
      "package.json",
      "src/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "artifactName": "AcademiQ-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AcademiQ Research",
      "displayLanguageSelector": false,
      "language": "1055",
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "publish": null
  }
}
