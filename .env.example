# AcademiQ Research — environment template
#
# This file is a placeholder for future non-secret configuration.
# The app does not read any secrets from environment variables.
#
# Non-secret update endpoint placeholder:
AQ_UPDATE_FEED_URL=https://updates.academiq.research

# Optional local release signing settings.
# Never commit real values. scripts/generate-signing-cert.ps1 writes
# scripts/.signing-thumbprint locally; scripts/sign-installer.ps1 can also
# read SIGNING_CERT_THUMBPRINT from the environment.
# SIGNING_CERT_THUMBPRINT=
# CERT_PASSWORD=
# TAURI_SIGNING_PRIVATE_KEY_PATH=%USERPROFILE%\.tauri\academiq-updater.key
