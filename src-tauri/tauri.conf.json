{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AcademiQ Research",
  "version": "1.23.0",
  "identifier": "com.academiq.research",
  "build": {
    "beforeDevCommand": "npm run dev:renderer",
    "beforeBuildCommand": "npm run build:renderer",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "windows": [
      {
        "title": "AcademiQ Research",
        "width": 1400,
        "height": 900
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' ipc: http://ipc.localhost https:; media-src 'self' data: blob: https:; worker-src 'self' blob:; object-src 'none'; frame-src 'none'; base-uri 'self'; form-action 'none';"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["../icon.ico"],
    "resources": [
      "binaries/pdfium.dll",
      "resources/dict/tr/index.aff",
      "resources/dict/tr/index.dic",
      "resources/dict/tr/LICENSE",
      "resources/fonts/fallback/*"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Turkish", "English"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  }
}
