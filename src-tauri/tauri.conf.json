{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AcademiQ Research",
  "version": "1.24.0",
  "identifier": "com.academiq.research",
  "build": {
    "beforeDevCommand": "npm run dev:renderer",
    "beforeBuildCommand": "npm run build:renderer",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AcademiQ Research",
        "width": 1400,
        "height": 900,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' ipc: http://ipc.localhost https:; media-src 'self' data: blob: https:; worker-src 'self' blob:; object-src 'none'; frame-src 'none'; base-uri 'self'; form-action 'none';"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "AcademiQ",
    "copyright": "Copyright (c) 2024 AcademiQ",
    "shortDescription": "AcademiQ Research",
    "longDescription": "AcademiQ Research - Akademik Yazim ve Kaynak Yonetim Uygulamasi",
    "icon": ["../icon.ico"],
    "externalBin": ["binaries/capture-agent"],
    "resources": [
      "binaries/pdfium.dll",
      "resources/dict/tr/index.aff",
      "resources/dict/tr/index.dic",
      "resources/dict/tr/LICENSE",
      "resources/fonts/fallback/*",
      "resources/browser-capture-extension/**/*",
      "../THIRD_PARTY_NOTICES.md"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Turkish", "English"],
        "displayLanguageSelector": false,
        "installerIcon": "../icon.ico",
        "startMenuFolder": "AcademiQ Research",
        "compression": "lzma"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEyNkI5NzhFN0I4QkFEQkYKUldTL3JZdDdqcGRyb2pjWWdJQ21tVkhFVDNGSHhiTlRoWG91T0t3b3BRdWJndGJ5TjJIWjd1cy8K",
      "endpoints": ["https://updates.academiq.research/{{target}}/{{current_version}}"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
